// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Models for Prediction Market Insights App

/// Represents a connected user wallet
model Wallet {
  id              String           @id @default(uuid())
  address         String           @unique // Lowercase wallet address (e.g. 0x...)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  preferences     Preference?
  insightsHistory InsightHistory[]
  savedMarkets    SavedMarket[]
}

/// Manages user interests and preferences for recommendations
model Preference {
  id              String   @id @default(uuid())
  walletId        String   @unique
  wallet          Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  // Comma-separated values for SQLite, or String[] for PostgreSQL
  categories      String   @default("")
  subCategories   String   @default("")
  tags            String   @default("")
  liquidityScale  String   @default("")
  timeframes      String   @default("")
}

/// Logs AI queries, analyzed markets, and reports generated
model InsightHistory {
  id              String   @id @default(uuid())
  walletId        String
  wallet          Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  marketTitle     String
  marketSlug      String?
  query           String   // The question the user asked the AI
  response        String   // The markdown response generated by the LLM
  provider        String   // gemini, openai, anthropic, or mockup-analyzer
  createdAt       DateTime @default(now())
}

/// Allows users to watch or bookmark specific prediction markets
model SavedMarket {
  id              String   @id @default(uuid())
  walletId        String
  wallet          Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  title           String
  slug            String
  category        String?
  savedAt         DateTime @default(now())

  @@unique([walletId, slug]) // Prevent bookmarking the same market twice
}
